# Environment variable template for Avalia FIT
# Copy this file to .env and fill in your local values.
# Spring Boot will read these automatically.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/avaliafit
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SERVER_PORT=8080
APP_JWT_SECRET=CHANGE_ME
APP_JWT_EXPIRATIONMS=3600000
